generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["filteredRelationCount"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int               @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String            @unique
  nickname          String?           @unique
  picture           String?
  birthDate         DateTime?         @db.Date
  phone             String?
  firstDrink        DateTime?         @db.Date
  becameFeut        DateTime?         @db.Date
  becameMember      DateTime?         @db.Date
  lastLoggedin      DateTime          @default(now())
  ldapId            String            @unique
  authentikId       String
  CommitteeMember   CommitteeMember[]
  MaluspuntGiven    Maluspunt[]       @relation("maluspuntGiver")
  MaluspuntReceived Maluspunt[]       @relation("maluspuntReceiver")
  StrafbakGiven     Strafbak[]        @relation("strafbakGiver")
  StrafbakReceived  Strafbak[]        @relation("strafbakReceiver")
}

model Committee {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  ldapId          String            @unique
  Acivity         Activity[]
  CommitteeMember CommitteeMember[]
}

model CommitteeMember {
  committeeId Int
  userId      Int
  joinDate    DateTime  @default(now()) @db.Date
  leaveDate   DateTime? @db.Date
  function    String    @default("Algemeen lid")
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  member      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([committeeId, userId, joinDate])
  @@index([userId], map: "CommitteeMember_userId_fkey")
}

model Strafbak {
  id          Int       @id @default(autoincrement())
  giverId     Int
  receiverId  Int
  reason      String?
  dateCreated DateTime  @default(now())
  dateDeleted DateTime?
  giver       User      @relation("strafbakGiver", fields: [giverId], references: [id])
  receiver    User      @relation("strafbakReceiver", fields: [receiverId], references: [id])

  @@index([giverId])
  @@index([receiverId], map: "Strafbak_receiverId_fkey")
}

model Maluspunt {
  id          Int      @id @default(autoincrement())
  giverId     Int
  receiverId  Int
  reason      String?
  dateCreated DateTime @default(now())
  amount      Int      @default(1)
  giver       User     @relation("maluspuntGiver", fields: [giverId], references: [id])
  receiver    User     @relation("maluspuntReceiver", fields: [receiverId], references: [id])

  @@index([giverId])
  @@index([receiverId], map: "Maluspunt_receiverId_fkey")
}

model Activity {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  start       DateTime
  location    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isActive    Boolean   @default(true)
  membersOnly Boolean   @default(false)
  committeeId Int
  organisedBy Committee @relation(fields: [committeeId], references: [id])

  @@index([committeeId], map: "Activity_committeeId_fkey")
}

model Ledger {
  id          Int      @id
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)
}

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  categoryId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)
  type        String   @default("Generiek")
  data        String   @db.LongText
}

model Transaction {
  id          Int      @id @default(autoincrement())
  ledgerId    Int
  description String
  price       Float
  fromId      Int
  toId        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  isActive    Boolean  @default(true)
}

model Sale {
  id        Int      @id @default(autoincrement())
  productId Int
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
}

model Declaration {
  id              Int      @id @default(autoincrement())
  ledgerId        Int
  amount          Float
  reason          String
  methodOfPayment String   @default("Eigen rekening")
  accepted        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
